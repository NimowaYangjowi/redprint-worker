# =============================================================================
# Transcode Worker — Environment Configuration
# =============================================================================
# Copy this file to .env.worker and fill in your credentials.
# docker compose reads .env.worker automatically.
# =============================================================================

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to true if DATABASE_URL points to a remote Railway instance
# TRANSCODE_ALLOW_REMOTE_DB=true

# ----------------------------------------------------------------------------
# Pipeline Flags (required)
# ----------------------------------------------------------------------------
TRANSCODE_PIPELINE_ENABLED=true

# Set to true to skip ffmpeg/R2 and test queue flow only
# TRANSCODE_DRY_RUN=true

# ----------------------------------------------------------------------------
# Cloudflare R2 Storage
# ----------------------------------------------------------------------------
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-public-domain.com

# ----------------------------------------------------------------------------
# DB Backup
# ----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_HOUR_UTC=4
BACKUP_RETENTION_DAYS=7
